{
  "lexicon": 1,
  "id": "com.latr.saved.item",
  "defs": {
    "main": {
      "type": "record",
      "description": "Declares that this user saved a subject (ATProto record or com.latr.saved.external wrapper) for read-later.",
      "key": "any",
      "record": {
        "type": "object",
        "required": ["subjectUri", "savedAt"],
        "properties": {
          "subjectUri": {
            "type": "string",
            "format": "at-uri"
          },
          "savedAt": {
            "type": "string",
            "format": "datetime"
          },
          "state": {
            "type": "string",
            "enum": ["unread", "archived"],
            "description": "Queue state; defaults to unread in clients when omitted."
          },
          "tags": {
            "type": "array",
            "items": { "type": "string", "maxLength": 128 },
            "maxLength": 64
          },
          "note": {
            "type": "string",
            "maxLength": 8192
          },
          "lastOpenedAt": {
            "type": "string",
            "format": "datetime"
          }
        }
      }
    }
  }
}
