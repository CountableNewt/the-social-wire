meta {
  name: Post AppView Read Mark
  type: http
  seq: 21
}

post {
  url: {{baseUrl}}/v1/appview/read-marks
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
  Content-Type: application/json
}

body:json {
  {
    "subjectUri": "{{entrySubjectUri}}",
    "readAt": "{{readMarkAt}}"
  }
}

docs {
  Upserts a Social Wire AppView read mark. Protocol read-state records are not written.
  Requires `ENABLE_THIN_APPVIEW=true`.
}
