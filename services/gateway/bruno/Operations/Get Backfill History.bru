meta {
  name: Get Operations Backfill History
  type: http
  seq: 25
}

get {
  url: {{baseUrl}}/v1/operations/backfills?view=history&limit=50
  body: none
  auth: none
}

headers {
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
}

tests {
  test("returns completed jobs only", function() {
    expect(res.getStatus()).to.equal(200);
    const body = res.getBody();
    expect(body.backfills.every((job) => job.status === "completed")).to.equal(true);
  });
}
