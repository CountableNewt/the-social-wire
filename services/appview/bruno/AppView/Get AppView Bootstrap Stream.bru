meta {
  name: Get AppView Bootstrap Stream
  type: http
  seq: 19
}

get {
  url: {{baseUrl}}/v1/appview/bootstrap-stream
  body: none
  auth: none
}

headers {
  Accept: application/x-ndjson
  Authorization: Bearer {{oauthAccessToken}}
  DPoP: {{dpopProof}}
}

docs {
  Progressive NDJSON bootstrap for signed-in reader load.

  Event order: `sidebarPriority` → `unreadCounts` → optional `selectedPublication` →
  optional `entriesPage` (first unread publication) → repeated `sidebarSection` slices →
  legacy `sidebarFolders` → `done`.

  New clients should prefer `sidebarSection` payloads over monolithic `sidebarFolders`.
  `unreadCounts` events include `generation`, `accuracy`, and `countedAt`.
  `sidebarSection` events may include `sectionGeneration`.
  Each line is a `BootstrapStreamEvent` with a `kind` field. Requires `ENABLE_THIN_APPVIEW=true`.
}
