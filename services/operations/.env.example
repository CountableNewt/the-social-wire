# The Social Wire Operations service environment
#
# Copy this file to `.env` for local/manual runs, or copy secrets into Fly with
# `fly secrets set ... --app <operations-app>`.
# Keep this file as documentation only; do not commit real credentials.
#
# Dev app:  the-social-wire-dev-operations
# Prod app: the-social-wire-prod-operations

# Runtime mode. Fly deployments must use `dev` or `prod`; `local` uses SQLite.
APP_ENV=dev

# HTTP bind settings. `PORT` should match `services/operations/fly.toml`.
PORT=8083
BIND_HOST=0.0.0.0

# Optional dotenv file path for local/manual runs. Process and Fly variables
# override values from the file.
DOTENV_PATH=.env

# Required when APP_ENV is `dev` or `prod`.
# Use the Supabase session pooler URI, not the direct db.* host.
# Format: postgresql://postgres.<project-ref>:<url-encoded-password>@aws-1-<region>.pooler.supabase.com:5432/postgres
SUPABASE_DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-us-east-1.pooler.supabase.com:5432/postgres

# Optional override for ATProto PLC discovery.
ATPROTO_PLC_URL=https://plc.directory

# Shared HMAC secret for Gateway -> Operations internal trust.
# Must be identical on gateway and operations.
GATEWAY_OPERATIONS_INTERNAL_SECRET=<openssl-rand-hex-32>

# Comma-delimited operator DIDs allowed to access protected operations routes.
OPERATIONS_OPERATOR_DIDS=did:plc:<operator-did>

# Hosted OAuth policy used when requests are not authenticated by internal trust.
OAUTH_GATEWAY_REQUIRE_KNOWN_CLIENT=true
OAUTH_GATEWAY_ALLOWED_CLIENT_IDS=https://api.testing.thesocialwire.app/oauth/client-metadata.json
OAUTH_GATEWAY_ALLOWED_AUDIENCES=

# Optional JWKS JSON used when an OAuth issuer omits signing keys from metadata.
OAUTH_ACCESS_TOKEN_SUPPLEMENTAL_JWKS_JSON=

# Runtime safety switches. Recovery and outbound alert delivery are intentionally
# disabled by default even when telemetry collection is enabled.
OPERATIONS_TELEMETRY_ENABLED=true
OPERATIONS_RECOVERY_ENABLED=false
OPERATIONS_ALERT_DELIVERY_ENABLED=false

# Optional signed alert webhook. Both values are required for delivery.
OPERATIONS_ALERT_WEBHOOK_URL=
OPERATIONS_ALERT_WEBHOOK_SECRET=

# Recovery replay overlap in microseconds.
OPERATIONS_REPLAY_REWIND_MICROSECONDS=5000000

# Alert thresholds. Time values are seconds; backlog is microseconds; ratios are
# decimal fractions between zero and one.
OPERATIONS_DISCONNECT_ALERT_SECONDS=120
OPERATIONS_IDLE_ALERT_SECONDS=300
OPERATIONS_COMMIT_STALE_SECONDS=300
OPERATIONS_BACKLOG_ALERT_MICROSECONDS=60000000
OPERATIONS_BACKFILL_STALL_SECONDS=600
OPERATIONS_INDEX_FAILURE_RATIO=0.01
OPERATIONS_INDEX_FAILURE_MINIMUM=10
OPERATIONS_APPVIEW_5XX_RATIO=0.02
OPERATIONS_APPVIEW_5XX_MINIMUM_REQUESTS=20
OPERATIONS_BOOTSTRAP_P95_SECONDS=5
OPERATIONS_ENTRIES_P95_SECONDS=2
OPERATIONS_UNREAD_COUNTS_P95_SECONDS=1.5
OPERATIONS_SIDEBAR_P95_SECONDS=3
OPERATIONS_DATABASE_QUERY_P95_SECONDS=1
OPERATIONS_RESPONSE_FRESHNESS_SECONDS=300
OPERATIONS_RESPONSE_FRESHNESS_RATIO=0.05

# Local-only fallback when APP_ENV=local. Fly should use SUPABASE_DATABASE_URL.
SQLITE_DB_PATH=./social-wire-operations.sqlite
