# The Social Wire Operations console
#
# Copy this file to `.env.local` for local development. Every variable in this
# file is exposed to the browser; never put secrets or private credentials here.

# Deployment environment. `next.config.ts` forwards server-side APP_ENV to the
# browser as NEXT_PUBLIC_APP_ENV. Use `dev` or `prod` for hosted deployments.
APP_ENV=dev

# Comma-delimited operator DIDs allowed to enter this console. The same value
# must be configured as OPERATIONS_OPERATOR_DIDS on the Operations service,
# which remains the authoritative security boundary. DIDs are public identifiers;
# `next.config.ts` forwards this value to the browser for immediate login gating.
OPERATIONS_OPERATOR_DIDS=did:plc:<operator-did>

# Gateway used by this deployment. Development and Production consoles must be
# separate deployments and must point at only their corresponding gateway.
NEXT_PUBLIC_OPERATIONS_GATEWAY_ORIGIN=https://api.testing.thesocialwire.app

# Optional hosted ATProto OAuth client metadata URL. Leave unset for local
# development, which uses loopback OAuth, and for production when metadata is
# served from the console's same origin at `/operations-client-metadata.json`.
# NEXT_PUBLIC_OPERATIONS_OAUTH_CLIENT_ID=https://operations.thesocialwire.app/operations-client-metadata.json

# Explicit local/demo-data mode. Never enable this in a deployed operator console.
NEXT_PUBLIC_OPERATIONS_DEMO_MODE=0
